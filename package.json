{
  "name": "usaprince",
  "version": "1.0.0",
  "description": "game",
  "scripts": {
    "start": "webpack serve --mode=development",
    "build": "run-s clean build-all generate-licenses",
    "debug-build": "run-s clean debug-build-all",
    "debug-build-game-only": "run-s clean debug-build-game",
    "build-only": "webpack --mode=production --env buildGame=true",
    "debug-build-all": "webpack --mode=development --env buildGame=true --env buildConfig=true",
    "debug-build-game": "webpack --mode=development --env buildGame=true",
    "build-all": "webpack --mode=production --env buildGame=true --env buildConfig=true",
    "build-config": "webpack --mode=production --env buildConfig=true",
    "clean": "rimraf js",
    "eslint": "eslint ./src/*.ts",
    "licenses-json": "license-checker --production --json > ./licenses/licenses.json",
    "licenses-text": "node ./licenses/extractLicenses.js ./licenses/licenses.json > ./licenses/LICENSE.packages.txt",
    "generate-licenses": "run-s licenses-json licenses-text",
    "ncu": "ncu -x pixi.js,@pixi/sound,@pixi/tilemap",
    "ncu-u": "ncu -u -x pixi.js,@pixi/sound,@pixi/tilemap"
  },
  "author": "hashsoft",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/fpsmeter": "^0.3.34",
    "@types/jest": "^29.5.14",
    "babel-loader": "^10.0.0",
    "copy-webpack-plugin": "^13.0.0",
    "eslint": "^9.23.0",
    "globals": "^16.0.0",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "license-checker": "^25.0.1",
    "npm-run-all2": "^7.0.2",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "terser-webpack-plugin": "^5.3.14",
    "tiled-types": "^1.3.0",
    "ts-jest": "^29.2.6",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.27.0",
    "webpack": "^5.98.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.0"
  },
  "dependencies": {
    "@pixi/sound": "^5.2.3",
    "@pixi/tilemap": "^4.1.0",
    "@pixi/unsafe-eval": "^7.4.3",
    "fpsmeter": "^0.3.1",
    "pixi.js": "^7.4.3"
  }
}
