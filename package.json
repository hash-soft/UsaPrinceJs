{
  "name": "usaprince",
  "version": "1.0.0",
  "description": "game",
  "scripts": {
    "start": "webpack serve --mode=development",
    "build": "run-s clean build-all generate-licenses",
    "debug-build": "run-s clean-debug debug-build-all",
    "debug-build-game-only": "run-s clean-debug debug-build-game",
    "build-only": "webpack --mode=production --env buildGame=true",
    "debug-build-all": "webpack --mode=development --env buildGame=true --env buildConfig=true",
    "debug-build-game": "webpack --mode=development --env buildGame=true",
    "build-all": "webpack --mode=production --env buildGame=true --env buildConfig=true",
    "build-config": "webpack --mode=production --env buildConfig=true",
    "clean": "rimraf js",
    "clean-debug": "rimraf js_dev",
    "eslint": "eslint ./src/*.ts",
    "licenses-json": "license-checker --production --json > ./licenses/licenses.json",
    "licenses-text": "node ./licenses/extractLicenses.js ./licenses/licenses.json > ./licenses/LICENSE.packages.txt",
    "licenses-text-android": "node ./licenses/extractLicenses.js ./licenses/licenses.json android > ./licenses/LICENSE.packages.android.txt",
    "generate-licenses": "run-s licenses-json licenses-text licenses-text-android",
    "ncu": "ncu -x pixi.js,@pixi/sound,@pixi/tilemap",
    "ncu-u": "ncu -u -x pixi.js,@pixi/sound,@pixi/tilemap"
  },
  "author": "hashsoft",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/fpsmeter": "^0.3.34",
    "@types/jest": "^30.0.0",
    "babel-loader": "^10.1.1",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^10.4.0",
    "globals": "^17.6.0",
    "html-webpack-plugin": "^5.6.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "license-checker": "^25.0.1",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "terser-webpack-plugin": "^5.6.0",
    "tiled-types": "^1.3.0",
    "ts-jest": "^29.4.9",
    "ts-loader": "^9.5.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.4"
  },
  "dependencies": {
    "@pixi/sound": "^5.2.3",
    "@pixi/tilemap": "^4.1.0",
    "@pixi/unsafe-eval": "^7.4.3",
    "fpsmeter": "^0.3.1",
    "pixi.js": "^7.4.3"
  }
}
