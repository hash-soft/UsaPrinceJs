<!doctype html>
<html lang="jp">
  <head>
    <title>up-config</title>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      http-equiv="Content-Security-Policy"
      content="script-src 'self' 'unsafe-inline';"
    />
    <link rel="stylesheet" type="text/css" href="./index_config.css" />
  </head>

  <body>
    <main class="w-full flex-grow">
      <img
        id="trash-svg"
        src="data:image/svg+xml;base64,"
        class="hidden"
      />
      <div class="flex justify-between items-center bg-gray-200">
        <nav class="flex flex-col sm:flex-row">
          <button
            name="tab-text"
            class="text-gray-600 py-1 px-6 block hover:text-blue-500 focus:outline-none text-blue-500 border-b-2 font-medium border-blue-500"
          >
            キーボード
          </button>
          <button
            name="tab-text"
            class="text-gray-600 py-1 px-6 block hover:text-blue-500 focus:outline-none"
          />
          ゲームパッド
        </nav>
        <div class="px-2">
          <button
            id="save"
            class="w-[120px] rounded-md bg-green-600 py-1 px-6 border border-transparent text-center text-sm text-white transition-all shadow-md hover:shadow-lg focus:bg-green-700 focus:shadow-none active:bg-green-700 hover:bg-green-700 active:shadow-none disabled:pointer-events-none disabled:opacity-50 disabled:shadow-none ml-2"
            type="button"
          >
            保存
          </button>
          <button
            id="cancel"
            class="w-[120px] rounded-md border border-transparent py-1 px-6 text-center text-sm transition-all text-slate-600 hover:bg-slate-100 focus:bg-slate-100 active:bg-slate-100 disabled:pointer-events-none disabled:opacity-50 disabled:shadow-none"
            type="button"
          >
            キャンセル
          </button>
        </div>
      </div>
      <div class="bg-white p-1">
        <div id="" name="tab-content" class="block">
          <table class="w-full text-md bg-white shadow-md rounded mb-4">
            <tbody>
              <tr class="border-b bg-violet-100">
                <th class="text-left p-3 px-5 w-[250px]">操作</th>
                <th class="text-left p-3 px-5">キー</th>
                <th class="text-left p-3 px-5"></th>
              </tr>
              <tr
                class="border-b hover:bg-yellow-300 bg-yellow-300"
                name="keyboard-row"
              >
                <td class="p-3 px-5">メニュー/決定</td>
                <td class="p-3 px-5">
                  <ul class="shadow-md"></ul>
                </td>
                <td class="p-3 px-5">
                  <div class="flex justify-end">
                    <button
                      type="button"
                      class="text-sm bg-red-500 hover:bg-red-700 text-white py-1 px-2 rounded focus:outline-none focus:shadow-outline"
                    >
                      削除
                    </button>
                  </div>
                </td>
              </tr>
              <tr class="border-b hover:bg-yellow-100" name="keyboard-row">
                <td class="p-3 px-5">閉じる/キャンセル</td>
                <td class="p-3 px-5">
                  <ul class="shadow-md"></ul>
                </td>
                <td class="p-3 px-5">
                  <div class="flex justify-end">
                    <button
                      type="button"
                      class="text-sm bg-red-500 hover:bg-red-700 text-white py-1 px-2 rounded focus:outline-none focus:shadow-outline"
                    >
                      削除
                    </button>
                  </div>
                </td>
              </tr>
              <tr class="border-b hover:bg-yellow-100" name="keyboard-row">
                <td class="p-3 px-5">マルチ/決定</td>
                <td class="p-3 px-5">
                  <ul class="shadow-md"></ul>
                </td>
                <td class="p-3 px-5">
                  <div class="flex justify-end">
                    <button
                      type="button"
                      class="text-sm bg-red-500 hover:bg-red-700 text-white py-1 px-2 rounded focus:outline-none focus:shadow-outline"
                    >
                      削除
                    </button>
                  </div>
                </td>
              </tr>
              <tr class="border-b hover:bg-yellow-100" name="keyboard-row">
                <td class="p-3 px-5">すべて閉じる/キャンセル</td>
                <td class="p-3 px-5">
                  <ul class="shadow-md"></ul>
                </td>
                <td class="p-3 px-5">
                  <div class="flex justify-end">
                    <button
                      type="button"
                      class="text-sm bg-red-500 hover:bg-red-700 text-white py-1 px-2 rounded focus:outline-none focus:shadow-outline"
                    >
                      削除
                    </button>
                  </div>
                </td>
              </tr>
              <tr class="border-b hover:bg-yellow-100" name="keyboard-row">
                <td class="p-3 px-5">上</td>
                <td class="p-3 px-5">
                  <ul class="shadow-md"></ul>
                </td>
                <td class="p-3 px-5">
