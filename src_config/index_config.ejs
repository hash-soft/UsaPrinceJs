              <tr class="border-b hover:bg-blue-100" name="gamepad-row">
                <td class="p-3 px-5">右</td>
                <td class="p-3 px-5">
                  <ul class="shadow-md"></ul>
                </td>
                <td class="p-3 px-5">
                  <div class="flex justify-end">
                    <button
                      type="button"
                      class="text-sm bg-red-500 hover:bg-red-700 text-white py-1 px-2 rounded focus:outline-none focus:shadow-outline"
                    >
