                      削除
                    </button>
                  </div>
                </td>
              </tr>
              <tr class="border-b hover:bg-blue-100" name="gamepad-row">
                <td class="p-3 px-5">閉じる/キャンセル</td>
                <td class="p-3 px-5">
                  <ul class="shadow-md"></ul>
                </td>
                <td class="p-3 px-5">
                  <div class="flex justify-end">
                    <button
                      type="button"
