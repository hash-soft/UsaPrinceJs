ode":1,"parameters":["※「でも　この国を　救ってくれた\nあんたたちに　いいこと　教えてやるよ。",0]},{"code":1,"parameters":["※「たまに　大きな鳥が　南の海から\n来るんだ。　ということは　海の先には\n陸地があるんじゃ　ないのか。",0]},{"code":53,"parameters":[]},{"code":52,"parameters":[]},{"code":1,"parameters":["※「この国は　どうなって\nしまうのだろうか。",0]},{"code":53,"parameters":[]}]},{"id":7,"name":"住人２","conditions":[],"list":[{"code":112,"parameters":[0,21,0]},{"code":14,"parameters":[21,4,84,0,0]},{"code":13,"parameters":[11,11,0,2,22,0,0]},{"code":33,"parameters":[11,3,0,0]},{"code":51,"parameters":[0]},{"code":1,"parameters":["※「うさぎ王国は　はるか高地に\nあるという　うわさだ。",0]},{"code":53,"parameters":[]},{"code":52,"parameters":[]},{"code":1,"parameters":["※「\\s[21]は　海をはさんだ島に\n城をかまえ　ドレイスを　狙っている。",0]},{"code":1,"parameters":["※「幸い　島は山に囲まれていて\nここまでは簡単に　これないのだが\n海から　こられると　危ないな。",0]},{"code":53,"parameters":[]}]}]